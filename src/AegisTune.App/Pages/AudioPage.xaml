<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AegisTune.App.Pages.AudioPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:AegisTune.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" Spacing="20">
            <Border Style="{StaticResource HeroSurfaceCardStyle}">
                <Grid ColumnSpacing="18" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="12">
                        <TextBlock Style="{StaticResource PageEyebrowTextStyle}" Text="AUDIO &amp; SOUND" />
                        <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Audio &amp; Sound" />
                        <TextBlock Style="{StaticResource PageLeadTextStyle}" Text="{x:Bind HeroSummaryLine}" TextWrapping="WrapWholeWords" />
                        <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind ModuleStatusLine}" TextWrapping="WrapWholeWords" />
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind ActionStatusLine}" TextWrapping="WrapWholeWords" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button
                                Click="RefreshAudio_Click"
                                Content="Review audio devices"
                                Style="{StaticResource PrimaryCtaButtonStyle}" />
                            <Button
                                Click="OpenSoundSettings_Click"
                                Content="Open Sound settings"
                                Style="{StaticResource SecondaryCtaButtonStyle}" />
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource CompactSurfaceCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="What happens next" />
                            <TextBlock
                                Style="{StaticResource MutedBodyTextStyle}"
                                Text="Review the default playback and recording devices first. Then adjust volume or mute only for the endpoint you actually want, or open the Windows sound tools for routing changes."
                                TextWrapping="WrapWholeWords" />
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind AudioDefaultsSummaryLine}" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource MetricCaptionTextStyle}" Text="Endpoints found" />
                        <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind EndpointCountLabel}" />
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind OutputInputSplitLabel}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource MetricCaptionTextStyle}" Text="Items to review" />
                        <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind IssueCountLabel}" />
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind RecommendedVolumeLabel}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource MetricCaptionTextStyle}" Text="Muted endpoints" />
                        <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind MutedCountLabel}" />
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind LowVolumeCountLabel}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource MetricCaptionTextStyle}" Text="Default route" />
                        <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind DefaultRouteSummaryLabel}" />
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind SnapshotCollectedAtLabel}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource CompactSurfaceCardStyle}">
                <CommandBar Style="{StaticResource ActionCommandBarStyle}">
                    <CommandBar.PrimaryCommands>
                        <AppBarButton Click="OpenSoundSettings_Click" Label="Sound settings" />
                        <AppBarButton Click="OpenVolumeMixer_Click" Label="Volume mixer" />
                        <AppBarButton Click="OpenClassicPlaybackPanel_Click" Label="Playback devices" />
                    </CommandBar.PrimaryCommands>
                    <CommandBar.SecondaryCommands>
                        <AppBarButton Click="OpenClassicRecordingPanel_Click" Label="Recording devices" />
                        <AppBarButton Click="OpenSoundControlPanel_Click" Label="Classic sound panel" />
                        <AppBarButton Click="OpenMicrophonePrivacy_Click" Label="Microphone privacy" />
                    </CommandBar.SecondaryCommands>
                </CommandBar>
            </Border>

            <TabView>
                <TabView.TabItems>
                    <TabViewItem Header="Playback">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled">
                            <StackPanel Padding="0,12,0,0" Spacing="16">
                                <Border Style="{StaticResource CompactSurfaceCardStyle}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Default playback device" />
                                        <TextBlock Style="{StaticResource PageLeadTextStyle}" Text="{x:Bind DefaultPlaybackName}" TextWrapping="WrapWholeWords" />
                                        <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind DefaultPlaybackSummary}" TextWrapping="WrapWholeWords" />
                                        <CommandBar Style="{StaticResource ActionCommandBarStyle}">
                                            <CommandBar.PrimaryCommands>
                                                <AppBarButton Click="DecreaseEndpointVolume_Click" IsEnabled="{x:Bind HasDefaultPlaybackDevice}" Label="Volume -" Tag="{x:Bind DefaultPlaybackDevice}" />
                                                <AppBarButton Click="IncreaseEndpointVolume_Click" IsEnabled="{x:Bind HasDefaultPlaybackDevice}" Label="Volume +" Tag="{x:Bind DefaultPlaybackDevice}" />
                                                <AppBarButton Click="ToggleEndpointMute_Click" IsEnabled="{x:Bind HasDefaultPlaybackDevice}" Label="{x:Bind DefaultPlaybackMuteActionLabel}" Tag="{x:Bind DefaultPlaybackDevice}" />
                                            </CommandBar.PrimaryCommands>
                                            <CommandBar.SecondaryCommands>
                                                <AppBarButton Click="SetEndpointRecommendedVolume_Click" IsEnabled="{x:Bind HasDefaultPlaybackDevice}" Label="Set review floor" Tag="{x:Bind DefaultPlaybackDevice}" />
                                            </CommandBar.SecondaryCommands>
                                        </CommandBar>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CompactSurfaceCardStyle}">
                                    <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind PlaybackSummary}" TextWrapping="WrapWholeWords" />
                                </Border>

                                <ItemsControl ItemsSource="{x:Bind PlaybackDevices}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="core:AudioEndpointRecord">
                                            <Border Margin="0,0,0,12" Style="{StaticResource SurfaceCardStyle}">
                                                <StackPanel Spacing="10">
                                                    <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="{x:Bind FriendlyName}" TextWrapping="WrapWholeWords" />
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind KindLabel}" />
                                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="•" />
                                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind StateLabel}" />
                                                    </StackPanel>
                                                    <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind StatusSummary}" TextWrapping="WrapWholeWords" />
                                                    <CommandBar Style="{StaticResource ActionCommandBarStyle}">
                                                        <CommandBar.PrimaryCommands>
                                                            <AppBarButton Click="DecreaseEndpointVolume_Click" Label="Volume -" Tag="{Binding}" />
                                                            <AppBarButton Click="IncreaseEndpointVolume_Click" Label="Volume +" Tag="{Binding}" />
                                                            <AppBarButton Click="ToggleEndpointMute_Click" Label="{x:Bind ToggleMuteLabel}" Tag="{Binding}" />
                                                        </CommandBar.PrimaryCommands>
                                                        <CommandBar.SecondaryCommands>
                                                            <AppBarButton Click="SetEndpointRecommendedVolume_Click" Label="Set review floor" Tag="{Binding}" />
                                                        </CommandBar.SecondaryCommands>
                                                    </CommandBar>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </TabViewItem>

                    <TabViewItem Header="Recording">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled">
                            <StackPanel Padding="0,12,0,0" Spacing="16">
                                <Border Style="{StaticResource CompactSurfaceCardStyle}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Default recording device" />
                                        <TextBlock Style="{StaticResource PageLeadTextStyle}" Text="{x:Bind DefaultRecordingName}" TextWrapping="WrapWholeWords" />
                                        <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind DefaultRecordingSummary}" TextWrapping="WrapWholeWords" />
                                        <CommandBar Style="{StaticResource ActionCommandBarStyle}">
                                            <CommandBar.PrimaryCommands>
                                                <AppBarButton Click="DecreaseEndpointVolume_Click" IsEnabled="{x:Bind HasDefaultRecordingDevice}" Label="Volume -" Tag="{x:Bind DefaultRecordingDevice}" />
                                                <AppBarButton Click="IncreaseEndpointVolume_Click" IsEnabled="{x:Bind HasDefaultRecordingDevice}" Label="Volume +" Tag="{x:Bind DefaultRecordingDevice}" />
                                                <AppBarButton Click="ToggleEndpointMute_Click" IsEnabled="{x:Bind HasDefaultRecordingDevice}" Label="{x:Bind DefaultRecordingMuteActionLabel}" Tag="{x:Bind DefaultRecordingDevice}" />
                                            </CommandBar.PrimaryCommands>
                                            <CommandBar.SecondaryCommands>
                                                <AppBarButton Click="SetEndpointRecommendedVolume_Click" IsEnabled="{x:Bind HasDefaultRecordingDevice}" Label="Set review floor" Tag="{x:Bind DefaultRecordingDevice}" />
                                            </CommandBar.SecondaryCommands>
                                        </CommandBar>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CompactSurfaceCardStyle}">
                                    <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind RecordingSummary}" TextWrapping="WrapWholeWords" />
                                </Border>

                                <ItemsControl ItemsSource="{x:Bind RecordingDevices}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="core:AudioEndpointRecord">
                                            <Border Margin="0,0,0,12" Style="{StaticResource SurfaceCardStyle}">
                                                <StackPanel Spacing="10">
                                                    <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="{x:Bind FriendlyName}" TextWrapping="WrapWholeWords" />
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind KindLabel}" />
                                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="•" />
                                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind StateLabel}" />
                                                    </StackPanel>
                                                    <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind StatusSummary}" TextWrapping="WrapWholeWords" />
                                                    <CommandBar Style="{StaticResource ActionCommandBarStyle}">
                                                        <CommandBar.PrimaryCommands>
                                                            <AppBarButton Click="DecreaseEndpointVolume_Click" Label="Volume -" Tag="{Binding}" />
                                                            <AppBarButton Click="IncreaseEndpointVolume_Click" Label="Volume +" Tag="{Binding}" />
                                                            <AppBarButton Click="ToggleEndpointMute_Click" Label="{x:Bind ToggleMuteLabel}" Tag="{Binding}" />
                                                        </CommandBar.PrimaryCommands>
                                                        <CommandBar.SecondaryCommands>
                                                            <AppBarButton Click="SetEndpointRecommendedVolume_Click" Label="Set review floor" Tag="{Binding}" />
                                                        </CommandBar.SecondaryCommands>
                                                    </CommandBar>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </TabViewItem>

                    <TabViewItem Header="Windows tools">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled">
                            <StackPanel Padding="0,12,0,0" Spacing="16">
                                <Border Style="{StaticResource CompactSurfaceCardStyle}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Built-in Windows sound tools" />
                                        <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind WindowsToolsSummary}" TextWrapping="WrapWholeWords" />
                                        <Grid ColumnSpacing="12" RowSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Button Grid.Row="0" Grid.Column="0" Click="OpenSoundSettings_Click" Content="Open Sound settings" Style="{StaticResource PrimaryCtaButtonStyle}" />
                                            <Button Grid.Row="0" Grid.Column="1" Click="OpenVolumeMixer_Click" Content="Open Volume mixer" Style="{StaticResource SecondaryCtaButtonStyle}" />
                                            <Button Grid.Row="1" Grid.Column="0" Click="OpenClassicPlaybackPanel_Click" Content="Open Playback devices" Style="{StaticResource SecondaryCtaButtonStyle}" />
                                            <Button Grid.Row="1" Grid.Column="1" Click="OpenClassicRecordingPanel_Click" Content="Open Recording devices" Style="{StaticResource SecondaryCtaButtonStyle}" />
                                            <Button Grid.Row="2" Grid.Column="0" Click="OpenSoundControlPanel_Click" Content="Open classic sound panel" Style="{StaticResource SecondaryCtaButtonStyle}" />
                                            <Button Grid.Row="2" Grid.Column="1" Click="OpenMicrophonePrivacy_Click" Content="Open microphone privacy" Style="{StaticResource SecondaryCtaButtonStyle}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CompactSurfaceCardStyle}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Manual test guidance" />
                                        <TextBlock
                                            Style="{StaticResource MutedBodyTextStyle}"
                                            Text="Use Playback devices to run a device test tone, use Recording devices to verify the active microphone level, and use Volume mixer when one app is too quiet or muted. Routing, sample rate, vendor DSP, and device-default switching remain on the native Windows or OEM surfaces."
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabViewItem>
                </TabView.TabItems>
            </TabView>
        </StackPanel>
    </ScrollViewer>
</Page>
