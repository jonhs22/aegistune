<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AegisTune.App.Pages.DriversPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:AegisTune.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid
            x:Name="LayoutRoot"
            Padding="{StaticResource PagePadding}"
            RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource HeroSurfaceCardStyle}">
                <Grid ColumnSpacing="24" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="HeroAuditColumn" Width="0" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="HeroAuditRow" Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="8">
                        <TextBlock Style="{StaticResource PageEyebrowTextStyle}" Text="DRIVERS &amp; FIRMWARE" />
                        <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Drivers &amp; Firmware" />
                        <TextBlock Style="{StaticResource PageLeadTextStyle}" Text="{x:Bind ModuleSubtitle}" />
                        <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind ModuleStatusLine}" />
                        <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind ActionStatusLine}" TextWrapping="WrapWholeWords" />
                        <TextBlock
                            Style="{StaticResource MutedBodyTextStyle}"
                            Text="1. Scan devices. 2. Check BIOS only if firmware review is needed. 3. Review the recommended driver path. 4. Install only from a local repository match or open the official support route."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <Border
                        x:Name="HeroAuditCard"
                        Grid.Row="1"
                        Grid.Column="0"
                        Style="{StaticResource InsetSurfaceCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Audit posture" />
                            <TextBlock Style="{StaticResource MetricCaptionTextStyle}" Text="Devices audited" />
                            <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind DeviceCountLabel}" />
                            <TextBlock Style="{StaticResource MetricCaptionTextStyle}" Text="Need review" />
                            <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind ReviewCountLabel}" />
                            <TextBlock Style="{StaticResource MetricCaptionTextStyle}" Text="Hardware-backed review" />
                            <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind HardwareBackedReviewCountLabel}" />
                            <TextBlock Style="{StaticResource MetricCaptionTextStyle}" Text="Generic-provider review" />
                            <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind GenericProviderCountLabel}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource SurfaceCardStyle}">
                    <CommandBar Style="{StaticResource ActionCommandBarStyle}">
                    <CommandBar.PrimaryCommands>
                        <AppBarButton Click="RefreshDrivers_Click" Label="Scan devices and driver status">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Refresh" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Name="CheckLatestBiosButton" Click="CheckLatestBios_Click" Label="Check official BIOS version">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Sync" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton Click="ExportDriverAudit_Click" Label="Export driver report">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Save" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                    </CommandBar.PrimaryCommands>
                    <CommandBar.SecondaryCommands>
                        <AppBarButton x:Name="OpenAuditFolderButton" Click="OpenAuditFolder_Click" Label="Open reports folder">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Folder" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Name="OpenFirmwareSupportButton" Click="OpenFirmwareSupport_Click" Label="Open OEM firmware support">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Help" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Name="OpenSystemInformationButton" Click="OpenSystemInformation_Click" Label="System information">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Document" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Name="CopyFirmwareBriefButton" Click="CopyFirmwareBrief_Click" Label="Copy firmware handoff">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Copy" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Name="CopyFlashPreparationButton" Click="CopyFlashPreparation_Click" Label="Copy flash prep kit">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Copy" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton Click="OpenDeviceManager_Click" Label="Device Manager">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Setting" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton Click="OpenWindowsUpdate_Click" Label="Windows Update">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Sync" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Name="OpenSelectedInfButton" Click="OpenSelectedInf_Click" Label="Open INF">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Document" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Name="CopyInstanceIdButton" Click="CopyInstanceId_Click" Label="Copy instance ID">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Copy" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Name="CopyHardwareIdsButton" Click="CopyHardwareIds_Click" Label="Copy hardware IDs">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Copy" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Name="CopyCompatibleIdsButton" Click="CopyCompatibleIds_Click" Label="Copy compatible IDs">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Copy" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Name="CopyTechnicianBriefButton" Click="CopyTechnicianBrief_Click" Label="Copy technician brief">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Copy" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Name="CopyRemediationPlanButton" Click="CopyRemediationPlan_Click" Label="Copy remediation plan">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Copy" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Name="CopyVerificationChecklistButton" Click="CopyVerificationChecklist_Click" Label="Copy verification checklist">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Copy" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Name="ExportRemediationPlanButton" Click="ExportRemediationPlan_Click" Label="Export remediation plan">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Save" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Name="OpenPlanFolderButton" Click="OpenPlanFolder_Click" Label="Open plan folder">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Folder" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                    </CommandBar.SecondaryCommands>
                </CommandBar>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource SurfaceCardStyle}">
                <Grid ColumnSpacing="18" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Local driver install" />
                        <TextBlock Style="{StaticResource PageLeadTextStyle}" Text="{x:Bind InstallReadinessHeadline}" TextWrapping="WrapWholeWords" />
                        <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind InstallReadinessDetail}" TextWrapping="WrapWholeWords" />
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind InstallModeLabel}" TextWrapping="WrapWholeWords" />
                        <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind InstallStatusLine}" TextWrapping="WrapWholeWords" />
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind InstallVerificationHint}" TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource InsetSurfaceCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Run next action" />
                            <Button
                                Click="InstallRepositoryCandidate_Click"
                                Content="Install selected local driver"
                                IsEnabled="{x:Bind HasSelectedRepositoryCandidate}"
                                Style="{StaticResource PrimaryCtaButtonStyle}" />
                            <Button
                                Click="OpenRepositoryCandidate_Click"
                                Content="Open selected local INF"
                                IsEnabled="{x:Bind HasSelectedRepositoryCandidate}"
                                Style="{StaticResource SecondaryCtaButtonStyle}" />
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="This automatic install lane uses pnputil only for the selected local INF match. It does not guess an OEM package from the web." TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid
                x:Name="MetricsGrid"
                Grid.Row="3"
                ColumnSpacing="16"
                RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition x:Name="MetricColumn2" Width="0" />
                    <ColumnDefinition x:Name="MetricColumn3" Width="0" />
                    <ColumnDefinition x:Name="MetricColumn4" Width="0" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="MetricRow2" Height="Auto" />
                    <RowDefinition x:Name="MetricRow3" Height="Auto" />
                    <RowDefinition x:Name="MetricRow4" Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    x:Name="MetricPriorityCard"
                    Grid.Row="0"
                    Grid.Column="0"
                    Style="{StaticResource InsetSurfaceCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource MetricCaptionTextStyle}" Text="Priority queue" />
                        <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind PriorityReviewCountLabel}" />
                        <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="Bad status, problem codes, or unsigned packages." />
                    </StackPanel>
                </Border>

                <Border
                    x:Name="MetricOemCard"
                    Grid.Row="1"
                    Grid.Column="0"
                    Style="{StaticResource InsetSurfaceCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource MetricCaptionTextStyle}" Text="OEM candidate" />
                        <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind HighConfidenceOemCountLabel}" />
                        <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="Review devices whose hardware evidence points strongly to an exact OEM package path." />
                    </StackPanel>
                </Border>

                <Border
                    x:Name="MetricFallbackCard"
                    Grid.Row="2"
                    Grid.Column="0"
                    Style="{StaticResource InsetSurfaceCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource MetricCaptionTextStyle}" Text="Compatible fallback" />
                        <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind CompatibleFallbackCountLabel}" />
                        <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="Windows exposed only compatible IDs, so these devices stay on technician review." />
                    </StackPanel>
                </Border>

                <Border
                    x:Name="MetricNoIdentifierCard"
                    Grid.Row="3"
                    Grid.Column="0"
                    Style="{StaticResource InsetSurfaceCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource MetricCaptionTextStyle}" Text="No identifier evidence" />
                        <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind NoIdentifierReviewCountLabel}" />
                        <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="Devices that still need review without hardware IDs or compatible IDs." />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid
                x:Name="WorkspaceGrid"
                Grid.Row="4"
                ColumnSpacing="20"
                RowSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="QueueColumn" Width="*" />
                    <ColumnDefinition x:Name="DetailsColumn" Width="0" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="QueueRow" Height="Auto" />
                    <RowDefinition x:Name="DetailsRow" Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    x:Name="QueuePanel"
                    Grid.Row="0"
                    Grid.Column="0"
                    Style="{StaticResource SurfaceCardStyle}">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Spacing="4">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Review queue" />
                            <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind FilterSummaryLabel}" />
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind QueueCapStatusLabel}" />
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind SearchStatusLabel}" />
                        </StackPanel>

                        <Border Grid.Row="1" Style="{StaticResource InsetSurfaceCardStyle}">
                            <Grid ColumnSpacing="18" RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{x:Bind QueueSelectionHeadline}" />
                                    <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind QueueSelectionStatusLine}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Recommended next lane" />
                                    <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind QueueSelectionNextLaneLabel}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Queue workflow" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind QueueSelectionCompactWorkflowLine}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <Grid Grid.Row="1" Grid.Column="1" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Current issue" />
                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind QueueSelectionIssueLabel}" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Selected local INF" />
                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind QueueSelectionCandidateCompactLine}" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <Grid
                            x:Name="QueueFilterGrid"
                            Grid.Row="2"
                            ColumnSpacing="12"
                            RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition x:Name="QueueFilterColumn" Width="0" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition x:Name="QueueFilterRow" Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBox
                                x:Name="DeviceSearchBox"
                                Grid.Row="0"
                                Grid.Column="0"
                                PlaceholderText="Search devices by name, class, provider, hardware ID, INF, or instance ID"
                                TextChanged="DeviceSearchBox_TextChanged" />

                            <ComboBox
                                x:Name="FilterModeBox"
                                Grid.Row="1"
                                Grid.Column="0"
                                Loaded="FilterModeBox_Loaded"
                                SelectionChanged="FilterModeBox_SelectionChanged">
                                <ComboBoxItem Content="Start with problem devices" />
                                <ComboBoxItem Content="High-risk devices" />
                                <ComboBoxItem Content="Critical hardware classes" />
                                <ComboBoxItem Content="All scanned devices" />
                            </ComboBox>
                        </Grid>

                        <ListView
                            x:Name="DriverQueueList"
                            Grid.Row="3"
                            Height="560"
                            MinHeight="480"
                            IsItemClickEnabled="True"
                            ItemClick="DriverQueueList_ItemClick"
                            SelectionChanged="DriverQueueList_SelectionChanged"
                            SelectionMode="Single"
                            VerticalAlignment="Stretch">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="2" />
                                    <Setter Property="Margin" Value="0,0,0,10" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="core:DriverDeviceRecord">
                                    <Border Style="{StaticResource InsetSurfaceCardStyle}">
                                        <StackPanel Spacing="10">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Spacing="4">
                                                    <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="{x:Bind FriendlyName}" TextWrapping="WrapWholeWords" />
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind ReviewBucketLabel}" />
                                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="•" />
                                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind EvidenceTierLabel}" />
                                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="•" />
                                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind MatchConfidenceLabel}" />
                                                    </StackPanel>
                                                </StackPanel>

                                                <TextBlock
                                                    Grid.Column="1"
                                                    HorizontalAlignment="Right"
                                                    Style="{StaticResource CaptionTextStyle}"
                                                    Text="{x:Bind HealthLabel}"
                                                    TextWrapping="WrapWholeWords" />
                                            </Grid>

                                            <Grid ColumnSpacing="14" RowSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Class" />
                                                    <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind DeviceClass}" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Provider" />
                                                    <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind ProviderLabel}" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2">
                                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Service" />
                                                    <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind ServiceLabel}" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Evidence" />
                                                    <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind ReviewQueueEvidenceLabel}" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Grid>

                                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind VersionLabel}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <StackPanel
                    x:Name="DetailsPanel"
                    Grid.Row="1"
                    Grid.Column="0"
                    Spacing="16">
                    <Border Style="{StaticResource SurfaceCardStyle}">
                        <Grid ColumnSpacing="18" RowSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="320" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="12">
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Selected right now" />
                                <TextBlock Style="{StaticResource PageLeadTextStyle}" Text="{x:Bind SelectedDeviceName}" />
                                <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind SelectedDeviceSummaryLine}" TextWrapping="WrapWholeWords" />
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind QueueSelectionWorkflowLine}" TextWrapping="WrapWholeWords" />
                                <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind QueueSelectionCandidateLine}" TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <Border Grid.Column="1" Style="{StaticResource InsetSurfaceCardStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Next button to press" />
                                    <TextBlock Style="{StaticResource PageLeadTextStyle}" Text="{x:Bind SelectedDriverNextActionHeadline}" TextWrapping="WrapWholeWords" />
                                    <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind SelectedDriverNextActionSummary}" TextWrapping="WrapWholeWords" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind SelectedDriverNextActionNextStep}" TextWrapping="WrapWholeWords" />
                                    <Button
                                        Click="RunSelectedPrimaryDriverAction_Click"
                                        Content="{x:Bind SelectedPrimaryDriverActionLabel}"
                                        Style="{StaticResource PrimaryCtaButtonStyle}"
                                        Visibility="{x:Bind SelectedPrimaryDriverActionVisibility}" />
                                    <Button
                                        Click="RunSelectedSecondaryDriverAction_Click"
                                        Content="{x:Bind SelectedSecondaryDriverActionLabel}"
                                        Style="{StaticResource SecondaryCtaButtonStyle}"
                                        Visibility="{x:Bind SelectedSecondaryDriverActionVisibility}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SurfaceCardStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Selected device" />
                            <TextBlock Style="{StaticResource PageLeadTextStyle}" Text="{x:Bind SelectedDeviceName}" />
                            <TextBlock Text="{x:Bind SelectedDeviceSummaryLine}" TextWrapping="WrapWholeWords" />

                            <StackPanel Spacing="4">
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Recommended action" />
                                <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind SelectedDeviceActionPlan}" TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Technician handoff" />
                                <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind SelectedDeviceTechnicianHandoff}" TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <Grid ColumnSpacing="18" RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Class" />
                                    <TextBlock Text="{x:Bind SelectedDeviceClass}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Manufacturer" />
                                    <TextBlock Text="{x:Bind SelectedDeviceManufacturer}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Provider" />
                                    <TextBlock Text="{x:Bind SelectedDeviceProvider}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Version" />
                                    <TextBlock Text="{x:Bind SelectedDeviceVersion}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Driver date" />
                                    <TextBlock Text="{x:Bind SelectedDeviceDate}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Signing" />
                                    <TextBlock Text="{x:Bind SelectedDeviceSigning}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Grid.Row="3" Grid.Column="0" Spacing="4">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Signer" />
                                    <TextBlock Text="{x:Bind SelectedDeviceSigner}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Grid.Row="3" Grid.Column="1" Spacing="4">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Priority context" />
                                    <TextBlock Text="{x:Bind SelectedDevicePriorityContext}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Grid.Row="4" Grid.Column="0" Spacing="4">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Service" />
