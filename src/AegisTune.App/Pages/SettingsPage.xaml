<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AegisTune.App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" Spacing="20">
            <Border Style="{StaticResource HeroSurfaceCardStyle}">
                <Grid ColumnSpacing="18" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="12">
                        <TextBlock Style="{StaticResource PageEyebrowTextStyle}" Text="WORKFLOW SETTINGS" />
                        <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Settings" />
                        <TextBlock
                            Style="{StaticResource PageLeadTextStyle}"
                            Text="Set the default review posture, health scan scope, export behavior, cleanup exclusions, and local driver repository roots."
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            Style="{StaticResource MutedBodyTextStyle}"
                            Text="{x:Bind SettingsSummaryLine}"
                            TextWrapping="WrapWholeWords" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button
                                Click="OpenSettingsFolder_Click"
                                Content="Open settings folder"
                                Style="{StaticResource PrimaryCtaButtonStyle}" />
                            <Button
                                Click="ResetAllSettings_Click"
                                Content="Reset defaults"
                                Style="{StaticResource SecondaryCtaButtonStyle}" />
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource CompactSurfaceCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Status" />
                            <TextBlock
                                Style="{StaticResource MutedBodyTextStyle}"
                                Text="{x:Bind SaveStatusLabel}"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{x:Bind StoragePathLabel}"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Session &amp; safety defaults" />
                    <TextBlock
                        Style="{StaticResource MutedBodyTextStyle}"
                        Text="These defaults affect execution mode, restore-point safety, export behavior, browser traces, and shell navigation."
                        TextWrapping="WrapWholeWords" />
                    <ToggleSwitch
                        x:Name="DryRunToggle"
                        Header="Keep dry-run mode on by default"
                        OffContent="Off"
                        OnContent="On"
                        Toggled="AnyToggle_Toggled" />
                    <ToggleSwitch
                        x:Name="RestorePointToggle"
                        Header="Require a restore point before driver and registry changes"
                        OffContent="Off"
                        OnContent="On"
                        Toggled="AnyToggle_Toggled" />
                    <ToggleSwitch
                        x:Name="BrowserCleanupToggle"
                        Header="Allow browser cache and trace cleanup targets"
                        OffContent="Off"
                        OnContent="On"
                        Toggled="AnyToggle_Toggled" />
                    <ToggleSwitch
                        x:Name="OpenExportFolderToggle"
                        Header="Open the export folder automatically after exports"
                        OffContent="Off"
                        OnContent="On"
                        Toggled="AnyToggle_Toggled" />
                    <ToggleSwitch
                        x:Name="CompactNavigationToggle"
                        Header="Use compact navigation in the left pane"
                        OffContent="Off"
                        OnContent="On"
                        Toggled="AnyToggle_Toggled" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="App updates" />
                    <TextBlock
                        Style="{StaticResource MutedBodyTextStyle}"
                        Text="Point AegisTune at one published update feed. The app can then check on launch, show when a newer version exists, and route MSIX installs or portable builds to the right download source."
                        TextWrapping="WrapWholeWords" />
                    <ToggleSwitch
                        x:Name="UpdateChecksToggle"
                        Header="Check for app updates when AegisTune opens"
                        OffContent="Off"
                        OnContent="On"
                        Toggled="AnyToggle_Toggled" />
                    <TextBox
                        x:Name="UpdateManifestUrlBox"
                        Header="Update manifest URL"
                        PlaceholderText="https://updates.ichiphost.com/aegistune/stable/stable.json"
                        TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Click="SaveUpdateFeed_Click" Content="Save update settings" />
                        <Button Click="CheckForUpdatesNow_Click" Content="Check now" />
                        <Button Click="OpenUpdateFeed_Click" Content="Open update source" />
                        <Button Click="ViewReleaseNotes_Click" Content="View release notes" />
                    </StackPanel>
                    <TextBlock
                        Style="{StaticResource CaptionTextStyle}"
                        Text="{x:Bind UpdateSettingsSummaryLabel}"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        Style="{StaticResource MutedBodyTextStyle}"
                        Text="{x:Bind UpdateFeedStatusLabel}"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        Style="{StaticResource CaptionTextStyle}"
                        Text="{x:Bind UpdateFeedDetailLabel}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Review defaults" />
                    <TextBlock
                        Style="{StaticResource MutedBodyTextStyle}"
                        Text="Use review-first mode to keep clutter down and surface only the items that need attention before showing the wider inventory."
                        TextWrapping="WrapWholeWords" />
                    <ToggleSwitch
                        x:Name="ReviewFirstListsToggle"
                        Header="Prefer review-first lists in Apps and Startup"
                        OffContent="Off"
                        OnContent="On"
                        Toggled="AnyToggle_Toggled" />
                    <ToggleSwitch
                        x:Name="RegistryResidueReviewToggle"
                        Header="Include registry and leftover review packs in Repair"
                        OffContent="Off"
                        OnContent="On"
                        Toggled="AnyToggle_Toggled" />
                    <TextBlock
                        Style="{StaticResource CaptionTextStyle}"
                        Text="{x:Bind ReviewDefaultsSummaryLabel}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Windows Health review scope" />
                    <TextBlock
                        Style="{StaticResource MutedBodyTextStyle}"
                        Text="Choose which evidence lanes the Windows Health module should review and how far back it should look."
                        TextWrapping="WrapWholeWords" />
                    <ToggleSwitch
                        x:Name="CrashEvidenceToggle"
                        Header="Review application crash evidence"
                        OffContent="Off"
                        OnContent="On"
                        Toggled="AnyToggle_Toggled" />
                    <ComboBox
                        x:Name="HealthCrashLookbackComboBox"
                        Header="Crash evidence lookback"
                        SelectionChanged="AnySelection_Changed">
                        <ComboBoxItem Tag="3" Content="Last 3 days" />
                        <ComboBoxItem Tag="7" Content="Last 7 days" />
                        <ComboBoxItem Tag="14" Content="Last 14 days" />
                        <ComboBoxItem Tag="30" Content="Last 30 days" />
                    </ComboBox>
                    <ToggleSwitch
                        x:Name="WindowsUpdateIssuesToggle"
                        Header="Review Windows Update warnings and errors"
                        OffContent="Off"
                        OnContent="On"
                        Toggled="AnyToggle_Toggled" />
                    <ComboBox
                        x:Name="HealthWindowsUpdateLookbackComboBox"
                        Header="Windows Update lookback"
                        SelectionChanged="AnySelection_Changed">
                        <ComboBoxItem Tag="7" Content="Last 7 days" />
                        <ComboBoxItem Tag="14" Content="Last 14 days" />
                        <ComboBoxItem Tag="30" Content="Last 30 days" />
                        <ComboBoxItem Tag="60" Content="Last 60 days" />
                    </ComboBox>
                    <ToggleSwitch
                        x:Name="ServiceReviewToggle"
                        Header="Review broken or stopped third-party services"
                        OffContent="Off"
                        OnContent="On"
                        Toggled="AnyToggle_Toggled" />
                    <ToggleSwitch
                        x:Name="ScheduledTaskReviewToggle"
                        Header="Review scheduled tasks with broken action targets"
                        OffContent="Off"
                        OnContent="On"
                        Toggled="AnyToggle_Toggled" />
                    <TextBlock
                        Style="{StaticResource CaptionTextStyle}"
                        Text="{x:Bind HealthReviewSummaryLabel}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Audio defaults" />
                    <TextBlock
                        Style="{StaticResource MutedBodyTextStyle}"
                        Text="These defaults control how Audio &amp; Sound steps volume changes and when default playback or recording devices are flagged for low-level review."
                        TextWrapping="WrapWholeWords" />
                    <ComboBox
                        x:Name="AudioVolumeStepComboBox"
                        Header="Volume step size"
                        SelectionChanged="AnySelection_Changed">
                        <ComboBoxItem Tag="5" Content="5%" />
                        <ComboBoxItem Tag="10" Content="10%" />
                        <ComboBoxItem Tag="15" Content="15%" />
                        <ComboBoxItem Tag="20" Content="20%" />
                    </ComboBox>
                    <ComboBox
                        x:Name="AudioRecommendedVolumeComboBox"
                        Header="Recommended default audio floor"
                        SelectionChanged="AnySelection_Changed">
                        <ComboBoxItem Tag="40" Content="40%" />
                        <ComboBoxItem Tag="50" Content="50%" />
                        <ComboBoxItem Tag="60" Content="60%" />
                        <ComboBoxItem Tag="70" Content="70%" />
                        <ComboBoxItem Tag="80" Content="80%" />
                    </ComboBox>
                    <TextBlock
                        Style="{StaticResource CaptionTextStyle}"
                        Text="{x:Bind AudioDefaultsSummaryLabel}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Cleanup exclusions" />
                    <TextBlock
                        Style="{StaticResource MutedBodyTextStyle}"
                        Text="Add one exclusion per line. Absolute paths stay path-specific; partial names match anywhere in the cleanup target path."
                        TextWrapping="WrapWholeWords" />
                    <TextBox
                        x:Name="CleanupExclusionsBox"
                        AcceptsReturn="True"
                        Height="140"
                        PlaceholderText="Example: keep.log&#10;C:\Users\john\AppData\Local\Temp\DoNotTouch"
                        TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Click="SaveCleanupExclusions_Click" Content="Save cleanup exclusions" />
                        <Button Click="ResetCleanupExclusions_Click" Content="Clear exclusions" />
                    </StackPanel>
                    <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind CleanupExclusionSummaryLabel}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Local driver repositories" />
                    <TextBlock
                        Style="{StaticResource MutedBodyTextStyle}"
                        Text="Add one vetted OEM or technician-curated driver repository root per line. AegisTune scans these local INF folders and does not pull anonymous driver packs from the web."
                        TextWrapping="WrapWholeWords" />
                    <TextBox
                        x:Name="DriverRepositoryPathsBox"
                        AcceptsReturn="True"
                        Height="140"
                        PlaceholderText="Example: D:\Drivers\OEM&#10;E:\ServiceDepot\Chipset"
                        TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Click="AddDriverRepositoryFolder_Click" Content="Add folder" />
                        <Button Click="SaveDriverRepositories_Click" Content="Save repositories" />
                        <Button Click="ResetDriverRepositories_Click" Content="Clear repositories" />
                    </StackPanel>
                    <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind DriverRepositorySummaryLabel}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
