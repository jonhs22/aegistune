<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AegisTune.App.Pages.CleanerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:AegisTune.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel x:Name="LayoutRoot" Padding="{StaticResource PagePadding}" Spacing="20">
            <Border Style="{StaticResource HeroSurfaceCardStyle}">
                <Grid ColumnSpacing="18" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="12">
                        <TextBlock Style="{StaticResource PageEyebrowTextStyle}" Text="SAFE CLEANUP" />
                        <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Cleanup" />
                        <TextBlock Style="{StaticResource PageLeadTextStyle}" Text="{x:Bind HeroSummaryLine}" TextWrapping="WrapWholeWords" />
                        <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind ModuleStatusLine}" TextWrapping="WrapWholeWords" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button
                                Click="RefreshPreview_Click"
                                Content="Review safe cleanup"
                                Style="{StaticResource PrimaryCtaButtonStyle}" />
                            <Button
                                Click="RunGuidedCleanup_Click"
                                Content="Run selected cleanup"
                                IsEnabled="{x:Bind HasSelectedTargets}"
                                Style="{StaticResource SecondaryCtaButtonStyle}" />
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource CompactSurfaceCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="What happens next" />
                            <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="Review the selected scope first. Cleanup stays preview-first unless dry-run mode is turned off in settings." TextWrapping="WrapWholeWords" />
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind ActionStatusLine}" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid x:Name="OverviewGrid" ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition x:Name="OverviewColumn2" Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="OverviewRow2" Height="0" />
                </Grid.RowDefinitions>

                <Border x:Name="CurrentPostureCard" Grid.Row="0" Grid.Column="0" Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Current posture" />
                        <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind GuidedCleanupModeLabel}" TextWrapping="WrapWholeWords" />
                        <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind CleanupExclusionSummary}" TextWrapping="WrapWholeWords" />
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind SelectedTargetNamesLabel}" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border x:Name="LiveTotalsCard" Grid.Row="0" Grid.Column="1" Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Live scan totals" />
                        <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind TotalReclaimableSizeLabel}" />
                        <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind TotalFileCountLabel}" TextWrapping="WrapWholeWords" />
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind ScanSummary}" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Selected cleanup scope" />

            <Border Style="{StaticResource CompactSurfaceCardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind SelectedTargetCountLabel}" />
                    <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind SelectedTargetNamesLabel}" TextWrapping="WrapWholeWords" />
                    <CommandBar Style="{StaticResource ActionCommandBarStyle}">
                        <CommandBar.PrimaryCommands>
                            <AppBarButton Click="SelectAllCleanupTargets_Click" Label="Select all safe targets" />
                            <AppBarButton Click="ClearCleanupSelection_Click" Label="Clear selection" />
                        </CommandBar.PrimaryCommands>
                    </CommandBar>
                </StackPanel>
            </Border>

            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Cleanup targets" />

            <ItemsControl ItemsSource="{x:Bind Targets}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="core:CleanupTargetScanResult">
                        <Border Margin="0,0,0,12" Style="{StaticResource SurfaceCardStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" />
                                <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind Description}" TextWrapping="WrapWholeWords" />
                                <CheckBox
                                    Checked="CleanupTargetSelection_Checked"
                                    Content="Include in the selected cleanup run"
                                    IsEnabled="{x:Bind CanExecute}"
                                    Loaded="CleanupTargetSelection_Loaded"
                                    Tag="{x:Bind Title}"
                                    Unchecked="CleanupTargetSelection_Unchecked" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="{x:Bind FormattedReclaimableSize}" />
                                    <TextBlock Text="•" />
                                    <TextBlock Text="{x:Bind FormattedFileCount}" />
                                </StackPanel>
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind StatusLabel}" TextWrapping="WrapWholeWords" />
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind DefaultSelectionLabel}" TextWrapping="WrapWholeWords" />
                                <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind LocationSummary}" TextWrapping="WrapWholeWords" />
                                <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind Notes}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Last execution details" />

            <Border Style="{StaticResource CompactSurfaceCardStyle}">
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind LastExecutionSummary}" TextWrapping="WrapWholeWords" />
                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind LastExecutionTimestampLabel}" />
                </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{x:Bind ExecutionResults}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="core:CleanupTargetExecutionResult">
                        <Border Margin="0,0,0,12" Style="{StaticResource SurfaceCardStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="{x:Bind OutcomeLabel}" />
                                    <TextBlock Text="•" />
                                    <TextBlock Text="{x:Bind ReclaimedBytesLabel}" />
                                    <TextBlock Text="•" />
                                    <TextBlock Text="{x:Bind DeletedFileCountLabel}" />
                                </StackPanel>
                                <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind Message}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
