<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AegisTune.App.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:AegisTune.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel x:Name="LayoutRoot" Padding="{StaticResource PagePadding}" Spacing="20">
            <Border Style="{StaticResource HeroSurfaceCardStyle}">
                <Grid ColumnSpacing="20" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="HeroMachineColumn" Width="0" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="HeroMachineRow" Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="12">
                        <TextBlock
                            Style="{StaticResource PageEyebrowTextStyle}"
                            Text="GUIDED MAINTENANCE" />
                        <TextBlock
                            Style="{StaticResource PageTitleTextStyle}"
                            Text="Windows maintenance without the guesswork" />
                        <TextBlock
                            Style="{StaticResource PageLeadTextStyle}"
                            Text="{x:Bind HeroSummaryLine}"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            Style="{StaticResource MutedBodyTextStyle}"
                            Text="{x:Bind DashboardContextLine}"
                            TextWrapping="WrapWholeWords" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Style="{StaticResource WorkflowChipBorderStyle}">
                                <TextBlock Style="{StaticResource WorkflowChipTextStyle}" Text="{x:Bind IssueChipLabel}" />
                            </Border>
                            <Border Style="{StaticResource WorkflowChipBorderStyle}">
                                <TextBlock Style="{StaticResource WorkflowChipTextStyle}" Text="{x:Bind ReadyChipLabel}" />
                            </Border>
                            <Border Style="{StaticResource WorkflowChipBorderStyle}">
                                <TextBlock Style="{StaticResource WorkflowChipTextStyle}" Text="{x:Bind SessionChipLabel}" />
                            </Border>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button
                                Click="StartGuidedReview_Click"
                                Content="{x:Bind PrimaryActionLabel}"
                                Style="{StaticResource PrimaryCtaButtonStyle}" />
                            <Button
                                Click="OpenReportsFromHero_Click"
                                Content="Open reports"
                                Style="{StaticResource SecondaryCtaButtonStyle}" />
                        </StackPanel>
                        <Border Style="{StaticResource CommandSurfaceCardStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Style="{StaticResource SectionEyebrowTextStyle}" Text="Start here" />
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{x:Bind WorkflowSummary}" />
                                <TextBlock
                                    Style="{StaticResource MutedBodyTextStyle}"
                                    Text="Use Home to pick the next module, then stay inside that workspace until you either export, verify, or undo the action."
                                    TextWrapping="WrapWholeWords" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Style="{StaticResource WorkflowChipBorderStyle}">
                                        <TextBlock Style="{StaticResource WorkflowChipTextStyle}" Text="1. Review" />
                                    </Border>
                                    <Border Style="{StaticResource WorkflowChipBorderStyle}">
                                        <TextBlock Style="{StaticResource WorkflowChipTextStyle}" Text="2. Act" />
                                    </Border>
                                    <Border Style="{StaticResource WorkflowChipBorderStyle}">
                                        <TextBlock Style="{StaticResource WorkflowChipTextStyle}" Text="3. Verify" />
                                    </Border>
                                    <Border Style="{StaticResource WorkflowChipBorderStyle}">
                                        <TextBlock Style="{StaticResource WorkflowChipTextStyle}" Text="4. Undo if needed" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border
                        x:Name="CurrentMachineCard"
                        Grid.Row="1"
                        Grid.Column="0"
                        Style="{StaticResource InsetSurfaceCardStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock
                                Style="{StaticResource SectionTitleTextStyle}"
                                Text="Current machine" />
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="{x:Bind DeviceName}" />
                            <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind OperatingSystemLabel}" />
                            <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind BuildLabel}" />
                            <Grid ColumnSpacing="16" RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Support identity" />
                                    <TextBlock Text="{x:Bind SupportIdentityLabel}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Firmware route" />
                                    <TextBlock Text="{x:Bind FirmwareRouteLabel}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="BIOS version" />
                                    <TextBlock Text="{x:Bind BiosVersionLabel}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="BIOS release" />
                                    <TextBlock Text="{x:Bind BiosReleaseLabel}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Firmware mode" />
                                    <TextBlock Text="{x:Bind FirmwareModeLabel}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Secure Boot" />
                                    <TextBlock Text="{x:Bind SecureBootLabel}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind SupportIdentitySourceLabel}" TextWrapping="WrapWholeWords" />
                            <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind FirmwareReadinessSummary}" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource CommandSurfaceCardStyle}">
                <Grid ColumnSpacing="16" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock Style="{StaticResource SectionEyebrowTextStyle}" Text="Live feed" />
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="App updates" />
                        <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind UpdateHeroLine}" TextWrapping="WrapWholeWords" />
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind UpdateDetailLine}" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Button Click="CheckAppUpdates_Click" Content="Check updates" Style="{StaticResource SecondaryCtaButtonStyle}" />
                        <Button Click="OpenUpdateAction_Click" Content="{x:Bind UpdateState.PrimaryActionLabel}" Style="{StaticResource PrimaryCtaButtonStyle}" />
                        <Button Click="OpenReleaseNotes_Click" Content="View release notes" Style="{StaticResource SecondaryCtaButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="MetricsGrid" ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition x:Name="MetricColumn2" Width="0" />
                    <ColumnDefinition x:Name="MetricColumn3" Width="0" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="MetricRow2" Height="Auto" />
                    <RowDefinition x:Name="MetricRow3" Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    x:Name="ModulesReadyCard"
                    Grid.Row="0"
                    Grid.Column="0"
                    Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource MetricCaptionTextStyle}" Text="Issues to review" />
                        <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind TotalIssueCount}" />
                        <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind PrimaryActionSummary}" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border
                    x:Name="ReviewSurfacesCard"
                    Grid.Row="1"
                    Grid.Column="0"
                    Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource MetricCaptionTextStyle}" Text="Modules ready" />
                        <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind ReadyModuleCountLabel}" />
                        <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="These modules are operational now and ready for guided review." />
                    </StackPanel>
                </Border>

                <Border
                    x:Name="SessionModeCard"
                    Grid.Row="2"
                    Grid.Column="0"
                    Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource MetricCaptionTextStyle}" Text="Session mode" />
                        <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind SessionModeLabel}" />
                        <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="Every action stays preview-first, source-aware, and exportable." />
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Style="{StaticResource SectionEyebrowTextStyle}" Text="Guided queue" />
            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Recommended next" />

            <ItemsControl ItemsSource="{x:Bind PriorityModules}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="core:ModuleSnapshot">
                        <Border Margin="0,0,0,12" Style="{StaticResource SurfaceCardStyle}">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="8">
                                    <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="{x:Bind Title}" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <InfoBadge Value="{x:Bind IssueCount}" />
                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind RiskLabel}" />
                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="•" />
                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind ReadinessLabel}" />
                                    </StackPanel>
                                    <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind StatusLine}" TextWrapping="WrapWholeWords" />
                                </StackPanel>

                                <Button
                                    Grid.Column="1"
                                    Click="OpenModule_Click"
                                    Content="{x:Bind OpenModuleLabel}"
                                    HorizontalAlignment="Right"
                                    Style="{StaticResource SecondaryCtaButtonStyle}"
                                    Tag="{x:Bind Section}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Style="{StaticResource SectionEyebrowTextStyle}" Text="Full workspace" />
            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="All modules" />

            <ItemsControl ItemsSource="{x:Bind Modules}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="core:ModuleSnapshot">
                        <Border Margin="0,0,0,12" Style="{StaticResource SurfaceCardStyle}">
                            <Grid ColumnSpacing="16" RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                                    <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="{x:Bind Title}" />
                                    <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind Subtitle}" TextWrapping="WrapWholeWords" />
                                </StackPanel>

                                <Button
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Click="OpenModule_Click"
                                    Content="{x:Bind OpenModuleLabel}"
                                    Style="{StaticResource SecondaryCtaButtonStyle}"
                                    Tag="{x:Bind Section}" />

                                <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                        <InfoBadge Value="{x:Bind IssueCount}" />
                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind RiskLabel}" />
                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="•" />
                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind AdminRequirementLabel}" />
                                    </StackPanel>

                                    <TextBlock
                                        Grid.Column="1"
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="{x:Bind StatusLine}"
                                        TextWrapping="WrapWholeWords" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Style="{StaticResource SectionEyebrowTextStyle}" Text="Session history" />
            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Recent activity" />

            <ItemsControl ItemsSource="{x:Bind Activities}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="core:RecentActivity">
                        <Border Margin="0,0,0,12" Style="{StaticResource CompactSurfaceCardStyle}">
                            <StackPanel Spacing="4">
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" />
                                <TextBlock Style="{StaticResource MutedBodyTextStyle}" Text="{x:Bind Detail}" TextWrapping="WrapWholeWords" />
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind OccurredAtLabel}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
