<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="AegisTune.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:AegisTune.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="AegisTune for Windows"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="{ThemeResource ShellWindowBackdropBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Title="Dashboard"
            BackRequested="TitleBar_BackRequested"
            IsBackButtonVisible="{x:Bind ContentFrame.CanGoBack}"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            PaneDisplayMode="Left"
            OpenPaneLength="272"
            CompactPaneLength="56"
            AlwaysShowHeader="False"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="True"
            SelectionChanged="NavView_SelectionChanged">
            <NavigationView.PaneHeader>
                <Border Margin="12,12,12,8" Style="{StaticResource PaneHeaderCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{StaticResource SectionEyebrowTextStyle}" Text="AegisTune stable" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border
                                Background="{ThemeResource ShellSurfaceBrush}"
                                BorderBrush="{ThemeResource ShellBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="8">
                                <Image Height="28" Source="ms-appx:///Assets/Square44x44Logo.scale-200.png" Width="28" />
                            </Border>
                            <StackPanel>
                                <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="AegisTune" />
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="guided maintenance cockpit" />
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Safer cleanup, repair, drivers, and firmware with evidence-first actions." />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Style="{StaticResource WorkflowChipBorderStyle}">
                                <TextBlock Style="{StaticResource WorkflowChipTextStyle}" Text="Portable-ready" />
                            </Border>
                            <Border Style="{StaticResource WorkflowChipBorderStyle}">
                                <TextBlock Style="{StaticResource WorkflowChipTextStyle}" Text="Preview-first" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </NavigationView.PaneHeader>
            <NavigationView.PaneFooter>
                <Border Margin="12,0,12,12" Style="{StaticResource CompactSurfaceCardStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock Style="{StaticResource SectionEyebrowTextStyle}" Text="Operator notes" />
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Use Home for the next guided step, Safety &amp; Undo for rollback history, and Settings for the live update feed." />
                    </StackPanel>
                </Border>
            </NavigationView.PaneFooter>
            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="DashboardItem"
                    Content="Home"
                    IsSelected="True"
                    Tag="Dashboard">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Home" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Windows Health" Tag="Health">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Favorite" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Audio &amp; Sound" Tag="Audio">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Volume" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemSeparator />
                <NavigationViewItem Content="Cleanup" Tag="Cleaner">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Delete" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Drivers &amp; Firmware" Tag="Drivers">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7F8;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Startup &amp; Background" Tag="Startup">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE823;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Apps &amp; Uninstall" Tag="Apps">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="AllApps" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Repair &amp; Recovery" Tag="Repair">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Sync" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Safety &amp; Undo" Tag="Safety">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Undo" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemSeparator />
                <NavigationViewItem Content="Reports" Tag="Reports">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Document" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="About" Tag="About">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Help" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>
            <Border Margin="0,0,16,16" Style="{StaticResource InsetSurfaceCardStyle}">
                <Frame x:Name="ContentFrame" />
            </Border>
        </NavigationView>
    </Grid>
</Window>
