<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="AegisTune.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AegisTune.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="ShellWindowBackdropBrush" Color="#FFF6F8FB" />
                    <SolidColorBrush x:Key="ShellSurfaceBrush" Color="#FFFFFFFF" />
                    <SolidColorBrush x:Key="ShellSurfaceAltBrush" Color="#FFF8FAFC" />
                    <SolidColorBrush x:Key="ShellSurfaceMutedBrush" Color="#FFF4F7FA" />
                    <SolidColorBrush x:Key="ShellHeroBrush" Color="#FFF8FBFD" />
                    <SolidColorBrush x:Key="ShellPanelBrush" Color="#FFF1F6F8" />
                    <SolidColorBrush x:Key="ShellBorderBrush" Color="#140F172A" />
                    <SolidColorBrush x:Key="ShellMutedTextBrush" Color="#FF64748B" />
                    <SolidColorBrush x:Key="ShellAccentBrush" Color="#FF0F766E" />
                    <SolidColorBrush x:Key="ShellAccentSecondaryBrush" Color="#FF115E59" />
                    <SolidColorBrush x:Key="ShellAccentSoftBrush" Color="#140F766E" />
                    <SolidColorBrush x:Key="ShellSuccessBrush" Color="#FF047857" />
                    <SolidColorBrush x:Key="ShellWarningBrush" Color="#FFB45309" />
                    <SolidColorBrush x:Key="ShellDangerBrush" Color="#FFB91C1C" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="ShellWindowBackdropBrush" Color="#FF0E141C" />
                    <SolidColorBrush x:Key="ShellSurfaceBrush" Color="#FF18202B" />
                    <SolidColorBrush x:Key="ShellSurfaceAltBrush" Color="#FF202A37" />
                    <SolidColorBrush x:Key="ShellSurfaceMutedBrush" Color="#FF111A27" />
                    <SolidColorBrush x:Key="ShellHeroBrush" Color="#FF14212E" />
                    <SolidColorBrush x:Key="ShellPanelBrush" Color="#FF0F1C28" />
                    <SolidColorBrush x:Key="ShellBorderBrush" Color="#29FFFFFF" />
                    <SolidColorBrush x:Key="ShellMutedTextBrush" Color="#FFD0D7E4" />
                    <SolidColorBrush x:Key="ShellAccentBrush" Color="#FF50C8BE" />
                    <SolidColorBrush x:Key="ShellAccentSecondaryBrush" Color="#FF8CE6DD" />
                    <SolidColorBrush x:Key="ShellAccentSoftBrush" Color="#2650C8BE" />
                    <SolidColorBrush x:Key="ShellSuccessBrush" Color="#FF34D399" />
                    <SolidColorBrush x:Key="ShellWarningBrush" Color="#FFFBBF24" />
                    <SolidColorBrush x:Key="ShellDangerBrush" Color="#FFF87171" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <Thickness x:Key="PagePadding">28,22,28,30</Thickness>

            <Style x:Key="SurfaceCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource ShellSurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource ShellBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="Padding" Value="18" />
            </Style>

            <Style x:Key="InsetSurfaceCardStyle" TargetType="Border" BasedOn="{StaticResource SurfaceCardStyle}">
                <Setter Property="Background" Value="{ThemeResource ShellSurfaceMutedBrush}" />
            </Style>

            <Style x:Key="HeroSurfaceCardStyle" TargetType="Border" BasedOn="{StaticResource SurfaceCardStyle}">
                <Setter Property="Background" Value="{ThemeResource ShellHeroBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource ShellAccentSoftBrush}" />
                <Setter Property="CornerRadius" Value="22" />
                <Setter Property="Padding" Value="20" />
            </Style>

            <Style x:Key="CompactSurfaceCardStyle" TargetType="Border" BasedOn="{StaticResource InsetSurfaceCardStyle}">
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="12" />
            </Style>

            <Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="26" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="PageEyebrowTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource ShellAccentBrush}" />
                <Setter Property="CharacterSpacing" Value="80" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="PageLeadTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="15" />
                <Setter Property="Foreground" Value="{ThemeResource ShellMutedTextBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="17" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="CardTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="MutedBodyTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource ShellMutedTextBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{ThemeResource ShellMutedTextBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="MetricValueTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="MetricCaptionTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
                <Setter Property="CharacterSpacing" Value="10" />
            </Style>

            <Style x:Key="ActionCommandBarStyle" TargetType="CommandBar">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="DefaultLabelPosition" Value="Right" />
                <Setter Property="IsDynamicOverflowEnabled" Value="True" />
            </Style>

            <Style x:Key="PrimaryCtaButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                <Setter Property="MinWidth" Value="168" />
                <Setter Property="Padding" Value="18,10" />
            </Style>

            <Style x:Key="SecondaryCtaButtonStyle" TargetType="Button">
                <Setter Property="MinWidth" Value="148" />
                <Setter Property="Padding" Value="18,10" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
